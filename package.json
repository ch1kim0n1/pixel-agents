{
  "name": "pixel-agents-workspace",
  "private": true,
  "version": "2.0.0",
  "description": "Council-native Pixel Agents monorepo (runtime core, council room library, and Electron app).",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "webview-ui",
    "apps/*"
  ],
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.9.0"
  },
  "scripts": {
    "bootstrap": "npm install --workspaces --include-workspace-root",
    "prepare:council-assets": "python scripts/process-dropped-council-assets.py",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build",
    "cometroom": "npm run prepare:council-assets && npm run dev:electron",
    "scenario:check": "node scripts/scenario-check.mjs",
    "dev:electron": "npm run dev --workspace apps/pixel-agents-electron",
    "build:electron": "npm run build --workspace apps/pixel-agents-electron",
    "build:council-room": "npm run build:lib --workspace webview-ui"
  }
}
