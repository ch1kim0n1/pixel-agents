{
  "name": "@pixel-agents/council-room",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/library/pixel-agents-council.umd.js",
  "module": "./dist/library/pixel-agents-council.es.js",
  "types": "./src/lib/index.ts",
  "engines": {
    "node": ">=22.12.0"
  },
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "import": "./src/lib/index.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsc -p tsconfig.lib.json && vite build --config vite.lib.config.ts",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@iconify-json/pixelarticons": "^1.2.4",
    "@iconify/react": "^6.0.2",
    "@pixel-agents/host-bridge": "0.1.0",
    "@pixel-agents/runtime-core": "0.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
