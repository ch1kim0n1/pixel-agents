{
  "name": "pixel-agents-electron",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "npm-run-all -p dev:renderer dev:electron",
    "dev:renderer": "vite --host 127.0.0.1 --port 5174",
    "dev:electron": "wait-on tcp:5174 && cross-env PIXEL_AGENTS_ELECTRON_RENDERER_URL=http://127.0.0.1:5174 electron .",
    "dev:inspect": "wait-on tcp:5174 && cross-env PIXEL_AGENTS_ELECTRON_RENDERER_URL=http://127.0.0.1:5174 PIXEL_AGENTS_OPEN_DEVTOOLS=1 electron .",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "start": "electron ."
  },
  "dependencies": {
    "@pixel-agents/council-room": "0.1.0",
    "@pixel-agents/runtime-core": "0.1.0",
    "chokidar": "^4.0.3",
    "electron-store": "^8.2.0",
    "node-pty": "^1.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "electron": "^37.7.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "wait-on": "^9.0.1"
  }
}
